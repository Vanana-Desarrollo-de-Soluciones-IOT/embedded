@startuml

' Render base classes/interfaces at the top, descendants below (top-down hierarchy)
top to bottom direction

' ============================================
' FRAMEWORK BASE CLASSES (ModestIoT)
' ============================================

' Structs
class Command {
    int id
    +Command(int commandId)
    +operator==(const Command& other) : bool
}

class Event {
    int id
    +Event(int eventId)
    +operator==(const Event& other) : bool
}

' Interfaces / Abstract Classes
abstract class CommandHandler {
    +handle(Command command)
}

abstract class EventHandler {
    +on(Event event)
}

' Device (inherits from both interfaces)
abstract class Device {
    +on(Event event)
    +handle(Command command)
}
Device -up-|> EventHandler
Device -up-|> CommandHandler

' Sensor (inherits from EventHandler)
class Sensor {
    protected int pin
    protected EventHandler* handler
    +Sensor(int pin, EventHandler* eventHandler = nullptr)
    +on(Event event)
}
Sensor -up-|> EventHandler

' Actuator (inherits from CommandHandler)
class Actuator {
    protected int pin
    protected CommandHandler* handler
    +Actuator(int pin, CommandHandler* commandHandler = nullptr)
    +handle(Command command)
}
Actuator -up-|> CommandHandler

' ============================================
' SENSORS (Clair System)
' ============================================

' SCD41 Sensor
class SCD41Sensor {
    - MySCD41 scd41
    - int sdaPin
    - int sclPin
    - unsigned long readInterval
    - unsigned long lastReadTime
    - bool dataReady
    - bool sensorInitialized
    - DFRobot_SCD4X::sSensorMeasurement_t lastMeasurement
    
    static const int DATA_READY_EVENT_ID
    
    +SCD41Sensor(int sda, int scl, unsigned long interval, EventHandler* handler = nullptr)
    +begin() : bool
    +update()
    +on(Event event)
    +getCO2() : uint16_t
    +getTemperature() : float
    +getHumidity() : float
    +printSerialNumber()
    +recalibrate(uint16_t targetCO2ppm) : bool
    +isDataReady() : bool
    +isInitialized() : bool
}
SCD41Sensor -up-|> Sensor

' PMS5003 Sensor
class PMS5003Sensor {
    - int rxPin
    - int txPin
    - int setPin
    - int resetPin
    - HardwareSerial* serial
    - unsigned long readInterval
    - unsigned long lastReadTime
    - bool sensorInitialized
    - bool dataReady
    - bool isSleeping
    - PMS5003Data lastData
    - uint8_t buffer[32]
    
    static const int DATA_READY_EVENT_ID
    static const int SLEEP_MODE_EVENT_ID
    static const int WAKE_MODE_EVENT_ID
    
    +PMS5003Sensor(int rx, int tx, int set, int reset, unsigned long interval, EventHandler* handler = nullptr)
    +begin() : bool
    +update()
    +on(Event event)
    +getData() : PMS5003Data
    +sleep()
    +wake()
    +reset()
    +isInitialized() : bool
    +isSleepingMode() : bool
    -readFrame(PMS5003Data& data) : bool
    -calculateChecksum(uint8_t* buffer, int length) : uint16_t
}
PMS5003Sensor -up-|> Sensor

' PMS5003Data struct
class PMS5003Data {
    + uint16_t pm1_0
    + uint16_t pm2_5
    + uint16_t pm10
    + bool valid
}

' ============================================
' SENSOR DEVICES (Wrappers)
' ============================================

class SCD41SensorDevice {
    - SCD41Sensor sensor
    
    +SCD41SensorDevice(int sdaPin, int sclPin, unsigned long readInterval)
    +on(Event event)
    +handle(Command command)
    +getSensor() : SCD41Sensor&
    +update()
}
SCD41SensorDevice -up-|> Device
SCD41SensorDevice *-- SCD41Sensor

class PMS5003SensorDevice {
    - PMS5003Sensor sensor
    
    +PMS5003SensorDevice(int rx, int tx, int set, int reset, unsigned long readInterval)
    +on(Event event)
    +handle(Command command)
    +getSensor() : PMS5003Sensor&
    +update()
}
PMS5003SensorDevice -up-|> Device
PMS5003SensorDevice *-- PMS5003Sensor

' ============================================
' ACTUATORS
' ============================================

' LED Actuator
class Led {
    - bool state
    
    static const int TOGGLE_LED_COMMAND_ID
    static const int TURN_ON_COMMAND_ID
    static const int TURN_OFF_COMMAND_ID
    static const Command TOGGLE_LED_COMMAND
    static const Command TURN_ON_COMMAND
    static const Command TURN_OFF_COMMAND
    
    +Led(int pin, bool initialState = false, CommandHandler* commandHandler = nullptr)
    +handle(Command command)
    +getState() : bool
    +setState(bool newState)
    +getPin() : int
}
Led -up-|> Actuator

' OLED Display Actuator
enum DisplayState {
    DISPLAY_ON
    DISPLAY_SLEEP
    DISPLAY_OFF
}

class DisplayData {
    + AirQuality airQuality
    + ParticulateMatter particulateMatter
    + AQI aqi
}

class OLEDDisplay {
    - Adafruit_SSD1306 display
    - int sdaPin
    - int sclPin
    - uint8_t i2cAddress
    - bool initialized
    - DisplayState currentState
    - unsigned long lastUpdateTime
    - unsigned long sleepAfterMs
    - DisplayData currentData
    
    static const int DISPLAY_ON_COMMAND
    static const int DISPLAY_OFF_COMMAND
    static const int DISPLAY_SLEEP_COMMAND
    static const int DISPLAY_WAKE_COMMAND
    
    +OLEDDisplay(int width, int height, int sda, int scl, uint8_t address, CommandHandler* handler = nullptr)
    +begin() : bool
    +updateData(const DisplayData& data)
    +refresh()
    +clear()
    +sleep()
    +wake()
    +off()
    +on()
    +handle(Command command)
    +autoPowerManagement()
    +setSleepTimeout(unsigned long ms)
    +getState() : DisplayState
    +isInitialized() : bool
}
OLEDDisplay -up-|> Actuator

' ============================================
' SERVICES
' ============================================

class WiFiService {
    - String ssid
    - String password
    - bool connected
    - unsigned long lastReconnectAttempt
    - unsigned long reconnectInterval
    - int connectionAttempts
    - void (*onConnectedCallback)()
    - void (*onDisconnectedCallback)()
    
    +WiFiService()
    +begin(const String& wifiSSID, const String& wifiPassword)
    +update()
    +connect(unsigned long timeoutMs = 10000) : bool
    +disconnect()
    +isConnected() : bool
    +getLocalIP() : String
    +getMacAddress() : String
    +getRSSI() : int
    +setCallbacks(void (*onConnect)(), void (*onDisconnect)())
    +printStatus()
}

class CloudService {
    - String endpointUrl
    - String deviceId
    - HTTPClient httpClient
    - bool enabled
    - unsigned long lastSendTime
    - unsigned long sendInterval
    - unsigned long successfulSends
    - unsigned long failedSends
    
    +CloudService()
    +begin(const String& url, const String& id, unsigned long interval = 30000)
    +sendData(const ClairData& data) : bool
    +sendDataThrottled(const ClairData& data) : bool
    +setEnabled(bool enable)
    +isEnabled() : bool
    +setSendInterval(unsigned long interval)
    +printStats()
    +testConnection() : bool
    -buildPayload(const ClairData& data) : String
}

' ============================================
' CLAIR SYSTEM CORE
' ============================================

' Air Quality Status
enum AirQualityStatus {
    OPTIMAL
    MODERATE
    CRITICAL
}

class AirQualityThresholds {
    + uint16_t pm25ModerateLimit
    + uint16_t pm25CriticalLimit
    + uint16_t pm10ModerateLimit
    + uint16_t pm10CriticalLimit
    + uint16_t co2ModerateLimit
    + uint16_t co2CriticalLimit
    + uint8_t humidityModerateLow
    + uint8_t humidityModerateHigh
    + uint8_t humidityCriticalLow
    + uint8_t humidityCriticalHigh
    
    +AirQualityThresholds()
}

' Unified Data Structure
class ClairData {
    + unsigned long timestamp
    + AirQualityData airQuality
    + ParticulateMatterData particulateMatter
    + AQIData airQualityIndex
    + AirQualityStatus status
    + String statusLabel
    
    +ClairData()
    +calculateAQI()
    +evaluateStatus(const AirQualityThresholds& thresholds)
    +print()
}

' Main Clair Device
class ClairPins {
    + int scd41_sda
    + int scd41_scl
    + int pms_rx
    + int pms_tx
    + int pms_set
    + int pms_reset
    
    +ClairPins()
}

class ClairDevice {
    - SCD41SensorDevice scd41Device
    - PMS5003SensorDevice pms5003Device
    - OLEDDisplay display
    - Led warningLed
    - ClairData currentData
    - unsigned long lastReportTime
    - unsigned long reportInterval
    - bool allSensorsReady
    - AirQualityThresholds thresholds
    - unsigned long lastLedBlink
    - bool ledBlinkState
    - WiFiService wifi
    - CloudService cloud
    
    static const int CLAIR_REPORT_COMMAND
    static const int CLAIR_CALIBRATE_COMMAND
    static const int CLAIR_RESET_COMMAND
    
    +ClairDevice(const ClairPins& pins = ClairPins(), unsigned long scd41Interval = 2000, unsigned long pmsInterval = 2000, unsigned long reportInterval = 10000, int displaySda = 21, int displayScl = 22, int ledPin = 2)
    +ClairDevice(int sda, int scl, int rx, int tx, int set, int reset, unsigned long scd41Interval = 2000, unsigned long pmsInterval = 2000, unsigned long reportInterval = 10000, int displaySda = 21, int displayScl = 22, int ledPin = 2)
    +begin() : bool
    +update()
    +on(Event event)
    +handle(Command command)
    +getCurrentData() : ClairData
    +forceReport()
    +isSystemReady() : bool
    +setAirQualityThresholds(const AirQualityThresholds& newThresholds)
    +setupWiFi(const String& ssid, const String& password)
    +setupCloud(const String& endpoint, const String& deviceId, unsigned long interval = 30000)
    +setCloudEnabled(bool enabled)
    +isCloudEnabled() : bool
    +isWiFiConnected() : bool
    +getWiFiIP() : String
    +getSCD41Device() : SCD41SensorDevice&
    +getPMS5003Device() : PMS5003SensorDevice&
    +getDisplay() : OLEDDisplay&
    +getWarningLed() : Led&
    +getCurrentStatus() : AirQualityStatus
    +getCurrentStatusLabel() : String
    
    - updateAirQualityData()
    - updateParticulateMatterData()
    - generateUnifiedReport()
    - updateWarningLed()
}
ClairDevice -up-|> Device
ClairDevice *-- SCD41SensorDevice
ClairDevice *-- PMS5003SensorDevice
ClairDevice *-- OLEDDisplay
ClairDevice *-- Led
ClairDevice *-- WiFiService
ClairDevice *-- CloudService
ClairDevice *-- ClairData
ClairDevice *-- AirQualityThresholds

' ============================================
' SKETCH PRINCIPAL (ClairSystem.ino)
' ============================================

class ClairSystemSketch {
    + ClairDevice clair
    + unsigned long lastStatusPrint
    + const unsigned long STATUS_PRINT_INTERVAL
    
    +setup()
    +loop()
    +processSerialCommands()
    +printStatus()
    +printBanner()
    +printHelp()
}
ClairSystemSketch *-- ClairDevice

@enduml